<!doctype html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/navbar') %>

    <main id="main-content">
      <section class="hero-section">
        <div class="container">
          <div class="row align-items-center gy-4">
            <div class="col-lg-8">
              <h1>Mark Ashkenazi</h1>
              <h2 class="hero-role">Software Tester / QA</h2>
              <p class="lead hero-lead">
                This portfolio documents my software projects, QA learning, testing practice, and practical development
                evidence.
                My work is also shaped by advocacy for web accessibility and social innovation, which influence how I
                think about useful, inclusive, and responsible digital systems.
              </p>              
            </div>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-heading">
            <h2>Featured projects</h2>
            <p>
              Recent and selected projects showing my software development foundation, QA direction, and project
              evidence.
            </p>
          </div>

          <div class="row g-4">
            <div class="col-md-6 col-lg-4">
              <article class="info-card h-100">
                <p class="small text-secondary mb-2">Enterprise Software Development</p>
                <h3>Audio Track Chat App</h3>
                <p>
                  Spring Boot team project with chat, audio-track search, playlist sharing, ratings, favourites,
                  JUnit 5 / Mockito tests, and a k6 load testing script.
                </p>
                <a href="/projects/audio-track-chat-app">View project</a>
              </article>
            </div>

            <div class="col-md-6 col-lg-4">
              <article class="info-card h-100">
                <p class="small text-secondary mb-2">Android Development</p>
                <h3>NuScan Android App</h3>
                <p>
                  Local-first Android product and nutrition catalogue with Room database, tags, store data,
                  map integration, email sharing, and remote JSON import.
                </p>
                <a href="/projects/nuscan-android-app">View project</a>
              </article>
            </div>

            <div class="col-md-6 col-lg-4">
              <article class="info-card h-100">
                <p class="small text-secondary mb-2">Software Design and Development</p>
                <h3>Whiskey Product Information System</h3>
                <p>
                  Java and JavaFX product information system with MySQL persistence, validation logic,
                  role-based screens, and JUnit 5 testing evidence.
                </p>
                <a href="/projects/whiskey-product-information-system">View project</a>
              </article>
            </div>
          </div>

          <div class="mt-4">
            <a class="btn btn-outline-primary" href="/projects">Browse all projects</a>
          </div>
        </div>
      </section>

    </main>

    <%- include('../partials/footer') %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
