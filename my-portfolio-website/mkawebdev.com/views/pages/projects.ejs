<!doctype html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/navbar') %>

  <main id="main-content" class="container page-main projects-page">
    <h1>Projects</h1>

    <p class="lead mb-4">
      Selected software testing, QA, accessibility, and university development projects that support my current portfolio direction.
    </p>

    <% const qaProjects = projects.filter(project => project.category === 'qa'); %>
    <% const universityProjects = projects.filter(project => project.category === 'uni'); %>

    <section class="project-section" aria-labelledby="qa-projects-heading">
      <div class="section-heading">
        <h2 id="qa-projects-heading">Software Tester / QA Projects</h2>
        <p>
          Project-based testing and QA artefacts developed through hands-on review of real applications, websites,
          APIs, databases, and selected software projects.
        </p>
      </div>

      <div class="row g-4">
        <% qaProjects.forEach(project => { %>
          <div class="col-md-6 col-lg-4">
            <article class="info-card h-100">
              <p class="small text-secondary mb-2">
                <%= project.type %>
              </p>

              <h3 class="h4">
                <%= project.title %>
              </h3>

              <p>
                <%= project.summary %>
              </p>

              <ul class="tag-list" aria-label="Testing and QA focus for <%= project.title %>">
                <% project.technologies.forEach(tech => { %>
                  <li>
                    <%= tech %>
                  </li>
                <% }) %>
              </ul>

              <p class="small text-secondary mt-3 mb-0">
                <%= project.status %>
              </p>

              <a class="btn btn-outline-primary mt-3" href="/projects/<%= project.slug %>">
                Project details
              </a>
            </article>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="project-section" aria-labelledby="university-projects-heading">
      <div class="section-heading">
        <h2 id="university-projects-heading">University Projects</h2>
        <p>
          Academic and capstone projects showing my software development foundation across Java, Spring Boot, Android,
          web, database, mobile, and team-based project work.
        </p>
      </div>

      <div class="row g-4">
        <% universityProjects.forEach(project => { %>
          <div class="col-md-6 col-lg-4">
            <article class="info-card h-100">
              <p class="small text-secondary mb-2">
                <%= project.type %>
              </p>

              <h3 class="h4">
                <%= project.title %>
              </h3>

              <p>
                <%= project.summary %>
              </p>

              <ul class="tag-list" aria-label="Technologies used for <%= project.title %>">
                <% project.technologies.forEach(tech => { %>
                  <li>
                    <%= tech %>
                  </li>
                <% }) %>
              </ul>

              <p class="small text-secondary mt-3 mb-0">
                <%= project.status %>
              </p>

              <a class="btn btn-outline-primary mt-3" href="/projects/<%= project.slug %>">
                Project details
              </a>
            </article>
          </div>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>