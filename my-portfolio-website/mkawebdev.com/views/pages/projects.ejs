<!doctype html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/navbar') %>

    <main id="main-content" class="container page-main">
      <h1>Projects</h1>
      <p class="lead mb-4">Selected development and testing projects that will become full portfolio case studies.</p>

      <div class="row g-4">
        <% projects.forEach(project=> { %>
          <div class="col-md-6 col-lg-4">
            <article class="info-card h-100">
              <p class="small text-secondary mb-2">
                <%= project.type %>
              </p>
              <h2 class="h4">
                <%= project.title %>
              </h2>
              <p>
                <%= project.summary %>
              </p>

              <ul class="tag-list" aria-label="Technologies used for <%= project.title %>">
                <% project.technologies.forEach(tech=> { %>
                  <li>
                    <%= tech %>
                  </li>
                  <% }) %>
              </ul>

              <p class="small text-secondary mt-3 mb-0">
                <%= project.status %>
              </p>
              <a class="btn btn-outline-primary mt-3" href="/projects/<%= project.slug %>">
                Project Details
              </a>
            </article>
          </div>
          <% }) %>
      </div>
    </main>

    <%- include('../partials/footer') %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>