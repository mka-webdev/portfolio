<!doctype html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <main id="main-content" class="container page-main">
    <nav aria-label="Breadcrumb" class="mb-4">
      <a href="/projects">Projects</a>
      <span aria-hidden="true"> / </span>
      <span><%= project.title %></span>
    </nav>

    <header class="page-header">
      <p class="text-secondary mb-2"><%= project.type %></p>
      <h1><%= project.title %></h1>
      <p class="lead"><%= project.summary %></p>
    </header>

    <section class="content-section pt-0">
      <h2>Documentation status</h2>
      <p><%= project.status %></p>

      <h2 class="mt-4">Technologies and tools</h2>
      <ul class="tag-list" aria-label="Technologies and tools used">
        <% project.technologies.forEach(tech => { %>
          <li><%= tech %></li>
        <% }) %>
      </ul>

      <h2 class="mt-4">Evidence to add</h2>
      <p>
        This page will later include project screenshots, testing artefacts, notes, links, and documentation relevant to this project.
      </p>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>