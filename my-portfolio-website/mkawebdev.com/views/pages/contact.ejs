<!doctype html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/navbar') %>

  <main id="main-content" class="container page-main contact-page">
    <header class="page-header">
      <h1>Contact</h1>

      <p class="lead">
        Get in touch about software testing, test automation, digital accessibility, or portfolio project work.
      </p>
    </header>

    <section class="text-section">
      <% if (formStatus === 'success') { %>
        <div class="alert alert-success" role="status">
          Thank you. Your message has been sent.
        </div>
      <% } %>

      <% if (formStatus === 'error') { %>
        <div class="alert alert-danger" role="alert">
          Sorry, something went wrong. Please check the required fields and try again.
        </div>
      <% } %>

      <form action="/contact" method="post" class="contact-form">
        <div class="mb-3">
          <label for="name" class="form-label">Name</label>
          <input
            type="text"
            class="form-control"
            id="name"
            name="name"
            autocomplete="name"
            required
          >
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            class="form-control"
            id="email"
            name="email"
            autocomplete="email"
            required
          >
        </div>

        <div class="mb-3">
          <label for="subject" class="form-label">
            Subject <span class="text-secondary">(optional)</span>
          </label>
          <input
            type="text"
            class="form-control"
            id="subject"
            name="subject"
          >
        </div>

        <div class="mb-4">
          <label for="message" class="form-label">Message</label>
          <textarea
            class="form-control"
            id="message"
            name="message"
            rows="7"
            required
          ></textarea>
        </div>

        <div class="visually-hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input
            type="text"
            id="website"
            name="website"
            tabindex="-1"
            autocomplete="off"
          >
        </div>

        <button type="submit" class="btn btn-primary">
          Send message
        </button>
      </form>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>