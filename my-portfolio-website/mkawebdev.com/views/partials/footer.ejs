<footer class="site-footer border-top">
  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <p class="footer-name">
          <a href="/">
            <%= site.name %>
          </a>
        </p>
        <p class="footer-role">Test Automation Engineer | Digital Accessibility Advocate</p>
      </div>

      <nav class="footer-links" aria-label="Footer navigation">
        <h2 class="footer-heading">Quick links</h2>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/testing">Testing</a></li>
          <li><a href="/accessibility">Accessibility</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <nav class="footer-socials" aria-label="Social links">
        <h2 class="footer-heading">Connect</h2>
        <ul>
          <li>
            <a class="icon-link icon-github" href="<%= site.socials.github %>" target="_blank"
              rel="noopener noreferrer">
              <span class="visually-hidden">GitHub profile opens in a new tab</span>
              <i class="fa-brands fa-github" aria-hidden="true"></i>
            </a>
          </li>
          <li>
            <a class="icon-link icon-linkedin" href="<%= site.socials.linkedin %>" target="_blank"
              rel="noopener noreferrer">
              <span class="visually-hidden">LinkedIn profile opens in a new tab</span>
              <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> Developed by <%= site.name %>
      </p>
    </div>
  </div>
</footer>