<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="487.0" prefWidth="725.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cqu.wis.view.LoginController">
   <children>
      <TextField fx:id="userNameTextField" layoutX="107.0" layoutY="135.0" prefHeight="25.0" prefWidth="132.0" promptText="user name" />
      <PasswordField fx:id="passwordTextField" layoutX="107.0" layoutY="180.0" prefHeight="25.0" prefWidth="132.0" promptText="password" />
      <Label layoutX="37.0" layoutY="139.0" text="User Name" />
      <Label layoutX="37.0" layoutY="184.0" text="Password" />
      <TextArea fx:id="messagesTextArea" layoutX="254.0" layoutY="135.0" prefHeight="281.0" prefWidth="412.0" />
      <Label layoutX="35.0" layoutY="98.0" text="Login Details">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Label layoutX="254.0" layoutY="98.0" text="Messages">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Button fx:id="loginButton" layoutX="29.0" layoutY="270.0" mnemonicParsing="false" onAction="#loginButtonClicked" text="Login" />
      <Button fx:id="changePasswordButton" layoutX="29.0" layoutY="313.0" mnemonicParsing="false" onAction="#changePasswordButtonClicked" text="Change Password" />
      <Button fx:id="clearButton" layoutX="29.0" layoutY="360.0" mnemonicParsing="false" onAction="#clearButtonClicked" text="Clear" />
      <Button fx:id="exitButton" layoutX="625.0" layoutY="430.0" mnemonicParsing="false" onAction="#exitButtonClicked" prefHeight="25.0" prefWidth="43.0" text="Exit" />
      <Label layoutX="35.0" layoutY="34.0" text="Login ">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
