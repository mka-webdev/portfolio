<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="702.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cqu.wis.view.PasswordController">
   <children>
      <TextField fx:id="userNameTextField" layoutX="122.0" layoutY="135.0" prefHeight="25.0" prefWidth="132.0" promptText="user name" />
      <PasswordField fx:id="oldPasswordTextField" layoutX="120.0" layoutY="180.0" prefHeight="25.0" prefWidth="132.0" promptText="password" />
      <Label layoutX="37.0" layoutY="139.0" text="User Name" />
      <Label layoutX="37.0" layoutY="184.0" text="Old Password" />
      <TextArea fx:id="messagesTextArea" layoutX="269.0" layoutY="135.0" prefHeight="164.0" prefWidth="397.0" />
      <Label layoutX="38.0" layoutY="84.0" text="Login Details">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Label layoutX="269.0" layoutY="84.0" text="Messages">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Button fx:id="submitButton" layoutX="36.0" layoutY="281.0" mnemonicParsing="false" onAction="#submitButtonClicked" text="Submit" />
      <Button fx:id="clearButton" layoutX="36.0" layoutY="332.0" mnemonicParsing="false" onAction="#clearButtonClicked" text="Clear" />
      <Button fx:id="exitButton" layoutX="623.0" layoutY="320.0" mnemonicParsing="false" onAction="#exitButtonClicked" prefHeight="25.0" prefWidth="43.0" text="Exit" />
      <PasswordField fx:id="newPasswordTextField" layoutX="120.0" layoutY="231.0" prefHeight="25.0" prefWidth="132.0" promptText="password" />
      <Label layoutX="37.0" layoutY="235.0" text="New Password" />
      <Label layoutX="37.0" layoutY="26.0" text="Change Password">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
